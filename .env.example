# Copy file nay thanh .env va dien gia tri that. KHONG commit file .env.
HF_TOKEN=

# Phase 3 - Streamlit App + job queue (mac dinh khop voi docker-compose.yml).
# Postgres map ra port 15432 (khong phai 5432 mac dinh) de tranh xung dot voi
# Postgres native co the da cai san tren may (xem HANDOFF.md muc 3).
DATABASE_URL=postgresql+psycopg2://subtitle_studio:subtitle_studio@localhost:15432/subtitle_studio
REDIS_URL=redis://localhost:6379/0
STORAGE_DIR=storage

# yt-dlp download tu YouTube co the bi chan "Sign in to confirm you're not a
# bot". Cach KHUYEN DUNG: tu dong lay cookie bang Playwright, xem
# subtitle_pipeline/infrastructure/cookie_refresh.py - chay 1 lan
# `python -m subtitle_pipeline.infrastructure.cookie_refresh --setup` (mo
# trinh duyet that de dang nhap), sau do dung nut "Lam moi cookie" trong
# trang Admin (hoac --refresh) bat cu khi nao cookie het han. Mac dinh ghi
# vao cookies.txt o goc repo.
YTDLP_COOKIES_FILE=cookies.txt

# Cau hinh AI pipeline (subtitle_pipeline/config.py) - doi WHISPER_MODEL sang
# large-v3 khi da xac nhan may dev chay duoc (xem HANDOFF.md Phase 1)
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=int8_float16
PIPELINE_DEVICE=cuda
PIPELINE_LANGUAGE=vi

# Phase 8 - Storage production (S3/MinIO). STORAGE_BACKEND=local (mac dinh)
# hoac =s3. Chi can dien S3_BUCKET/S3_PREFIX khi dung s3.
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=

# Backend FastAPI (backend/) cho UI React (frontend/) - xem HANDOFF.md muc
# "UI React + FastAPI". SESSION_SECRET_KEY: chuoi ngau nhien dai, tao bang
# `python -c "import secrets; print(secrets.token_hex(32))"`. Tai khoan
# ADMIN la tai khoan CHUNG (khong nam trong bang users) - ai dang nhap bang
# cap nay deu co quyen admin.
SESSION_SECRET_KEY=doi-thanh-chuoi-ngau-nhien-dai
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# Gui email khi job hoan thanh (chi gui LINK toi trang chi tiet job, KHONG
# dinh kem video - xem backend/email_sender.py). Mac dinh dung Gmail SMTP:
# 1. Bat 2-Step Verification cho tai khoan Gmail dung de gui.
# 2. Tao App Password tai https://myaccount.google.com/apppasswords (16 ky
#    tu, KHONG phai mat khau Gmail thuong).
# 3. Dien SMTP_USER = email Gmail, SMTP_PASSWORD = App Password vua tao.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=VietDub Studio
# URL frontend that (doi sang domain that khi deploy) - dung de dung link
# trong email gui nguoi dung.
FRONTEND_URL=http://localhost:5173
