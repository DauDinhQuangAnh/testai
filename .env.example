# Copy file nay thanh .env va dien gia tri that. KHONG commit file .env.
HF_TOKEN=

# Phase 3 - Streamlit App + job queue (mac dinh khop voi docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://subtitle_studio:subtitle_studio@localhost:5432/subtitle_studio
REDIS_URL=redis://localhost:6379/0
STORAGE_DIR=storage

# Cau hinh AI pipeline (subtitle_pipeline/config.py) - doi WHISPER_MODEL sang
# large-v3 khi da xac nhan may dev chay duoc (xem HANDOFF.md Phase 1)
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=int8_float16
PIPELINE_DEVICE=cuda
PIPELINE_LANGUAGE=vi

# Phase 6 - Auth. SESSION_SECRET_KEY: chuoi ngau nhien dai (vd: python -c
# "import secrets; print(secrets.token_hex(32))"), KHONG dung gia tri mac dinh
# nay trong production.
SESSION_SECRET_KEY=change-me-to-a-random-secret-in-production

# Phase 7 - Billing (Stripe). Lay tu Stripe Dashboard (test mode truoc).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Phase 8 - Storage production (S3/MinIO). STORAGE_BACKEND=local (mac dinh)
# hoac =s3. Chi can dien S3_BUCKET/S3_PREFIX khi dung s3.
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=
